# Optional: enables arena announcer voice (Deepgram TTS).
# Without this key the app still builds and runs; arena voice is disabled.
DEEPGRAM_API_KEY=

# Optional: Redis move-memory layer (move cards, leaderboards, similarity
# search, fight history). If reachable, Redis becomes the source of truth;
# otherwise the app falls back to JSON files under web/data.
# Defaults to redis://127.0.0.1:6379 when unset.
REDIS_URL=redis://127.0.0.1:6379
# Set to 1 to force the filesystem fallback even if Redis is running.
REDIS_DISABLED=
