# Optional: enables arena announcer voice (Deepgram TTS).
# Without this key the app still builds and runs; arena voice is disabled.
DEEPGRAM_API_KEY=

# Fetch.ai Judge bridge (run: cd agents && uvicorn web_bridge:app --port 8010)
# Ingest falls back to local heuristics if the bridge is unreachable.
JUDGE_BRIDGE_URL=http://127.0.0.1:8010
