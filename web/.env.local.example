# Optional: enables arena announcer voice (Deepgram TTS).
# Without this key the app still builds and runs; arena voice is disabled.
DEEPGRAM_API_KEY=

# Redis move-memory layer (move cards, leaderboards, similarity search, fight
# history). When reachable, Redis is the source of truth; otherwise the app
# falls back to JSON files under web/data.
#
# Use your hosted Redis Cloud database. Get the host, port, and default-user
# password from the Redis Cloud console (Databases -> your DB -> Security):
REDIS_URL=redis://default:<password>@<host>:<port>
# For a local Redis instead: redis://127.0.0.1:6379
# Defaults to redis://127.0.0.1:6379 when unset.
#
# Set to 1 to force the filesystem fallback even if Redis is reachable.
REDIS_DISABLED=
