# Copy to .env and fill in. Never commit the real .env (it is gitignored).

# ASI:One LLM key (https://asi1.ai/dashboard/api-keys)
ASI_API_KEY=

# Agentverse API key (for mailbox / publishing agent details)
AGENTVERSE_API_KEY=

# Deterministic agent identities (any stable strings; change before deploy)
JUDGE_SEED=ghost-fighter-judge-seed-change-me
COACH_SEED=ghost-fighter-coach-seed-change-me

# Ports for local runs
JUDGE_PORT=8001
COACH_PORT=8002

# Paste the Coach's printed agent1q... address here after first running coach_agent.py
COACH_ADDRESS=

# Paste the Judge's printed agent1q... address here after first running judge_agent.py
JUDGE_ADDRESS=

# Local endpoint shortcuts for the web bridge. These let the web app call the
# running uAgents directly without relying on Agentverse mailbox discovery.
COACH_ENDPOINT=http://127.0.0.1:8002/submit
JUDGE_ENDPOINT=http://127.0.0.1:8001/submit

# Optional: set BRIDGE_MODE=core to bypass uAgent transport for local debugging.
BRIDGE_MODE=agent
